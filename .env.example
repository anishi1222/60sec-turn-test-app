ANTHROPIC_MESSAGES_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_API_KEY=replace-with-your-key
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_VERSION=2023-06-01

# Defaults are tuned for Claude Haiku prompt caching.
PROMPT_CACHE_TURNS=20
PROMPT_CACHE_MAX_TOKENS=160
PROMPT_CACHE_TTL=5m
PROMPT_CACHE_STREAMING=false
PROMPT_CACHE_CONTEXT_REPETITIONS=80
PROMPT_CACHE_TIMEOUT_SECONDS=120
PROMPT_CACHE_INTERVAL_SECONDS=0

# Optional: use this for APIM subscription-key style gateways.
# ANTHROPIC_API_KEY_HEADER=Ocp-Apim-Subscription-Key

# Optional: write per-turn usage and responses to JSON Lines.
# PROMPT_CACHE_OUTPUT_JSONL=prompt-cache-results.jsonl

# Optional: pass an Anthropic beta header if your endpoint requires one.
# ANTHROPIC_BETA=
